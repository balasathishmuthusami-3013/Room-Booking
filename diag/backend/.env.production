# ════════════════════════════════════════════════════════
#  BACKEND .env  — Copy these into Render Environment Variables
#  Dashboard → Your Service → Environment → Add Variable
# ════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────
PORT=10000
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────
# Replace with your Atlas connection string
# Get it from: Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.fjikz2v.mongodb.net/room-booking?retryWrites=true&w=majority&appName=Cluster0

# ── Frontend URL (your Netlify URL) ───────────────────
# Set this AFTER you deploy to Netlify
CLIENT_URL=https://your-site-name.netlify.app

# ── JWT Secrets (generate strong random strings!) ─────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ── Amadeus API (already in your .env) ────────────────
AMADEUS_API_KEY=LBzJn6kepD4T20JAcz6p9m4W646ScDf3
AMADEUS_API_SECRET=jymNhpJ5IbG539yk
AMADEUS_ENV=test

# ── Payments (add your keys when ready) ───────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── OpenAI (for chat) ─────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

# ── Tax & Charges ─────────────────────────────────────
TAX_RATE=0.12
SERVICE_CHARGE_RATE=0.05
FULL_REFUND_HOURS=48
PARTIAL_REFUND_HOURS=24
PARTIAL_REFUND_PERCENT=50

# ── Admin ─────────────────────────────────────────────
ADMIN_EMAIL=admin@hotelapp.com
