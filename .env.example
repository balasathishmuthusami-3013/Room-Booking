# ─────────────────────────────────────────────
#  Task Manager – Environment Variables
#  Copy this file to .env and fill in values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=your-jwt-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ─────────────────────────────────
DATABASE_URL=sqlite:///./task_manager.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/task_manager

# ── Razorpay ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
# Set to "test" for sandbox, "live" for production
RAZORPAY_MODE=test

# ── Strike (Bitcoin / Crypto) ─────────────────
STRIKE_API_KEY=your_strike_api_key_here
STRIKE_WEBHOOK_SECRET=your_strike_webhook_secret_here
# Set to "sandbox" for testing, "production" for live
STRIKE_ENV=sandbox

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
